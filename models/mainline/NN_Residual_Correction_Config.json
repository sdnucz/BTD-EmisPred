{
  "enabled": true,
  "type": "training_oof_nearest_neighbor_residual_correction",
  "library_file": "NN_Residual_Correction_Library.csv",
  "smiles_column": "SMILES",
  "solvent_column": "Solvent",
  "residual_column": "oof_residual_true_minus_pred",
  "morgan_radius": 2,
  "morgan_bits": 2048,
  "k": 10,
  "shrink": 1.1,
  "same_solvent": false,
  "gate_mode": "fixed",
  "min_max_similarity": 0.5,
  "correction_cap_nm": 40.0,
  "formula": "y_final = y_xgb + clip(shrink * weighted_mean(kNN OOF residuals), -correction_cap_nm, +correction_cap_nm) if max_similarity >= min_max_similarity; otherwise y_final = y_xgb"
}